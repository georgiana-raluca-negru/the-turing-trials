# --- DATABASE CONFIG ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=turing_db

# --- SECURITY ---
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_use_openssl_rand_hex_32

# --- FRONTEND CONFIG ---
# Local dev: browser hits the backend directly on port 8001
NEXT_PUBLIC_API_URL=http://localhost:8001
# Production (behind Nginx): browser hits the public domain; Nginx routes /api/* to FastAPI
# NEXT_PUBLIC_API_URL=http://the-turing-trials.games

# --- OAUTH (optional — leave empty to disable OAuth login) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:8001/api/auth/oauth/google/callback
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_REDIRECT_URI=http://localhost:8001/api/auth/oauth/github/callback

# --- LLM / AI ENGINE CONFIG ---
# OPENAI_API_KEY=your_api_key_here
# OPENAI_BASE_URL=https://api.minimax.io/v1
# DEFAULT_MODEL_NAME=MiniMax-Text-01